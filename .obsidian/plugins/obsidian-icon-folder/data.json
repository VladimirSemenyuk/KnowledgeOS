{
  "settings": {
    "migrated": 6,
    "iconPacksPath": ".obsidian/icons",
    "fontSize": 16,
    "emojiStyle": "native",
    "iconColor": null,
    "recentlyUsedIcons": [
      "LiTextSelect",
      "LiSpeech",
      "LiFileText",
      "LiHeart",
      "LiLightbulb"
    ],
    "recentlyUsedIconsSize": 5,
    "rules": [
      {
        "rule": "AGENTS.md",
        "icon": "LiFileCog",
        "for": "everything",
        "order": 0,
        "color": "#d17cf8"
      },
      {
        "rule": "(?<!AGENTS)\\.md$",
        "icon": "LiFile",
        "for": "everything",
        "order": 1,
        "useFilePath": true
      },
      {
        "rule": "Context.md",
        "icon": "LiFileQuestionMark",
        "for": "everything",
        "order": 2,
        "color": "#0099ff"
      },
      {
        "rule": ".pdf$",
        "icon": "LiFileBadge",
        "for": "files",
        "order": 3,
        "color": "#e94957"
      }
    ],
    "extraMargin": {
      "top": 0,
      "right": 4,
      "bottom": 0,
      "left": 0
    },
    "iconInTabsEnabled": true,
    "iconInTitleEnabled": true,
    "iconInTitlePosition": "inline",
    "iconInFrontmatterEnabled": false,
    "iconInFrontmatterFieldName": "icon",
    "iconColorInFrontmatterFieldName": "iconColor",
    "iconsBackgroundCheckEnabled": false,
    "iconsInNotesEnabled": true,
    "iconsInLinksEnabled": true,
    "iconIdentifier": ":",
    "lucideIconPackType": "native",
    "debugMode": false,
    "useInternalPlugins": false
  },
  "Clients": "LiFolders",
  "Frameworks": "LiLightbulb",
  "Personal": "LiHeart",
  "Posts": "LiFileText",
  "Talks": "LiSpeech",
  "Templates": "LiTextSelect"
}